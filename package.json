{
  "name": "contextcraft-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "vitest run",
    "test:e2e": "pnpm --filter @contextcraft/debug test:e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:property": "vitest run property",
    "test:bench": "vitest bench",
    "test:bench:baseline": "vitest bench --outputJson benchmarks/baseline.json",
    "lint": "eslint .",
    "size-limit": "pnpm --filter contextcraft exec size-limit",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.15.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.15.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unicorn": "^56.0.0",
    "fast-check": "^3.23.2",
    "globals": "^17.4.0",
    "prettier": "^3.3.3",
    "size-limit": "^11.2.0",
    "tsup": "^8.5.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.15.0",
    "vitest": "^2.1.9"
  }
}
