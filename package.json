{
  "name": "slotmux-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.14.2",
  "engines": {
    "node": ">=20.19.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  },
  "scripts": {
    "build": "turbo run build --filter=!@slotmux/example-*",
    "test": "vitest run",
    "test:e2e": "pnpm --filter @slotmux/debug test:e2e",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:property": "vitest run property",
    "test:perf-sla": "NODE_OPTIONS='--expose-gc' vitest run packages/core/__tests__/integration/performance-slas.integration.test.ts",
    "test:bench": "vitest bench",
    "test:bench:baseline": "vitest bench --outputJson benchmarks/baseline.json",
    "bench:ci": "vitest bench --outputJson benchmarks/current.json && node scripts/bench-ci-report.mjs",
    "bench:latency-report": "vitest run --config packages/core/vitest.benchmark-report.config.ts",
    "bench:longmemeval:download": "node benchmarks/longmemeval/download-dataset.mjs",
    "bench:longmemeval": "tsx benchmarks/longmemeval/run-benchmark.mts",
    "bench:longmemeval:evaluate": "tsx benchmarks/longmemeval/evaluate.mts",
    "bench:longmemeval:report": "tsx benchmarks/longmemeval/report.mts",
    "bench:longmemeval:trace": "tsx benchmarks/longmemeval/trace-question.mts",
    "bench:longmemeval:analyze": "tsx benchmarks/longmemeval/analyze-trace.mts",
    "chat": "tsx scripts/chat/chat.mts",
    "lint": "eslint .",
    "audit": "pnpm audit --audit-level=high",
    "verify:core-runtime-deps": "node scripts/verify-core-runtime-deps.mjs",
    "size-limit": "pnpm --filter slotmux exec size-limit && pnpm --filter @slotmux/providers exec size-limit",
    "lint:fix": "eslint . --fix",
    "typecheck": "turbo run typecheck --filter=!@slotmux/example-*",
    "docs:dev": "pnpm --filter @slotmux/docs dev",
    "docs:build": "pnpm --filter @slotmux/docs run site:build",
    "docs:preview": "pnpm --filter @slotmux/docs preview",
    "test:docs": "tsc --noEmit -p docs/snippets/tsconfig.json",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.15.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.15.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-unicorn": "^63.0.0",
    "fast-check": "^4.6.0",
    "globals": "^17.4.0",
    "prettier": "^3.3.3",
    "size-limit": "^12.0.1",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^2.1.9"
  }
}
