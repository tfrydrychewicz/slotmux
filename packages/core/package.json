{
  "name": "contextcraft",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "typesVersions": {
    ">=4.0": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contextcraft/compression": "workspace:*",
    "@contextcraft/providers": "workspace:*",
    "nanoid": "^5.0.9",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@anthropic-ai/tokenizer": "*",
    "gpt-tokenizer": "*",
    "tiktoken": "*"
  },
  "peerDependenciesMeta": {
    "tiktoken": {
      "optional": true
    },
    "@anthropic-ai/tokenizer": {
      "optional": true
    },
    "gpt-tokenizer": {
      "optional": true
    }
  },
  "size-limit": [
    {
      "name": "contextcraft (core)",
      "path": "dist/index.js",
      "limit": "15 kB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@size-limit/file": "^11.0.0",
    "expect-type": "^1.3.0"
  }
}
