{
  "name": "@slotmux/providers",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "typesVersions": {
    ">=4.0": {
      "*": ["./dist/index.d.ts"]
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "tiktoken": "*",
    "@anthropic-ai/tokenizer": "*",
    "gpt-tokenizer": "*"
  },
  "peerDependenciesMeta": {
    "tiktoken": { "optional": true },
    "@anthropic-ai/tokenizer": { "optional": true },
    "gpt-tokenizer": { "optional": true }
  },
  "dependencies": {
    "@slotmux/tokenizers": "workspace:*",
    "slotmux": "workspace:*"
  },
  "size-limit": [
    {
      "name": "@slotmux/providers (barrel)",
      "path": "dist/index.js",
      "limit": "25 kB",
      "gzip": true
    }
  ],
  "devDependencies": {
    "@size-limit/file": "^12.0.1",
    "@types/node": "^22.10.0",
    "gpt-tokenizer": "^3.4.0",
    "tiktoken": "^1.0.22",
    "typescript": "^5.7.2"
  }
}
