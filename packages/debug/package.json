{
  "name": "@slotmux/debug",
  "version": "1.0.0-rc.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "typesVersions": {
    ">=4.0": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build:ui": "vite build -c ui/vite.config.mts",
    "build": "pnpm run build:ui && tsup",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "lint": "eslint src/ ui/src e2e/",
    "typecheck": "tsc --noEmit && tsc --noEmit -p ui/tsconfig.json"
  },
  "dependencies": {
    "slotmux": "workspace:*",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@preact/preset-vite": "^2.10.4",
    "@types/ws": "^8.18.1",
    "preact": "^10.29.0",
    "vite": "^8.0.3"
  }
}
