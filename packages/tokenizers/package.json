{
  "name": "@slotmux/tokenizers",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "typesVersions": {
    ">=4.0": {
      "*": [
        "./dist/index.d.ts"
      ]
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "slotmux": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/tokenizer": "*",
    "gpt-tokenizer": "*",
    "tiktoken": "*"
  },
  "peerDependenciesMeta": {
    "tiktoken": {
      "optional": true
    },
    "@anthropic-ai/tokenizer": {
      "optional": true
    },
    "gpt-tokenizer": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/tokenizer": "^0.0.4",
    "@types/node": "^22.10.0",
    "gpt-tokenizer": "^3.4.0",
    "tiktoken": "^1.0.22"
  }
}
